{
    "name": "nexphant/runtime",
    "description": "Runtime core for nexphant framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Nexphant\\Runtime\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "ext-pdo": "*",
        "nexphant/core": "^0.0",
        "nexphant/support": "^0.0",
        "nexphant/observability": "^0.0"
    },
    "suggest": {
        "ext-apcu": "For runtime cache and APCu queue driver",
        "ext-redis": "For Redis queue, cache, and event bus"
    }
}

